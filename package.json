{
  "name": "vibedocu",
  "version": "1.2.0",
  "description": "VibeDocs - AI-powered vibe coding document assistant",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --publish onTag",
    "rebuild": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@milkdown/core": "^7.6.2",
    "@milkdown/ctx": "^7.6.2",
    "@milkdown/kit": "^7.6.2",
    "@milkdown/plugin-clipboard": "^7.6.2",
    "@milkdown/plugin-history": "^7.6.2",
    "@milkdown/plugin-indent": "^7.6.2",
    "@milkdown/plugin-listener": "^7.6.2",
    "@milkdown/preset-commonmark": "^7.6.2",
    "@milkdown/prose": "^7.6.2",
    "@milkdown/react": "^7.6.2",
    "@openrouter/ai-sdk-provider": "^0.4.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^4.1.0",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.vibedocu.app",
    "productName": "VibeDocs",
    "publish": {
      "provider": "github",
      "owner": "TsukimiTei",
      "repo": "vibedocu"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "npmRebuild": true,
    "files": [
      "out/**/*",
      "resources/**/*"
    ]
  }
}
